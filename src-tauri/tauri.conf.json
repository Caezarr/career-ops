{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Career OS",
  "version": "0.0.3",
  "identifier": "com.caezarr.career-ops",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "Career OS",
        "label": "main",
        "url": "index.html",
        "width": 1400,
        "height": 900,
        "minWidth": 1024,
        "minHeight": 700,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false,
        "alwaysOnTop": false,
        "skipTaskbar": false,
        "shadow": true,
        "visible": true,
        "dragDropEnabled": false
      },
      {
        "title": "Copilot",
        "label": "copilot",
        "url": "index.html#copilot",
        "width": 460,
        "height": 560,
        "minWidth": 360,
        "minHeight": 48,
        "resizable": true,
        "fullscreen": false,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "hiddenTitle": true,
        "shadow": true,
        "visibleOnAllWorkspaces": true,
        "contentProtected": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "deep-link": {
      "desktop": {
        "schemes": ["careeros"]
      }
    },
    "updater": {
      "active": true,
      "endpoints": [
        "https://api.careeros.fr/v1/updates/{{target}}/{{arch}}/{{current_version}}"
      ],
      "dialog": false,
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDY0MzBBNzVCNDBGQTUwNjUKUldSbFVQcEFXNmN3WkpudWJ3dlJvMXBWWnB3MzRHY0xJZlNXeVRkZGhqZ3JaVlA1NU5vTWg5T2kK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "dmg",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "category": "Productivity",
    "shortDescription": "Career OS — dashboard, war room, CV manager, and stealth live interview copilot",
    "longDescription": "Mac app that owns the entire job-hunt loop: track applications, tailor CV variants, drill prep questions, and get a CV-grounded stealth coach during live interviews.",
    "macOS": {
      "infoPlist": "Info.plist"
    }
  }
}
